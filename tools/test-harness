test_build_index_produces_dist() {
  # build_index runs and produces dist/index.html. The total number of lesson
  # cards rendered (published + future) must equal the 41-entry master list,
  # regardless of how many lessons have been authored so far.
  rm -rf dist
  elixir tools/build_index/build_index.exs \
    --lessons lessons --shared shared/reveal --out dist >/tmp/build-index.out 2>&1 \
    || { cat /tmp/build-index.out >&2; fail "build_index exited non-zero"; }
  assert_file "dist/index.html"
  assert_dir "dist/shared/reveal"
  assert_grep "Elixir Training" "dist/index.html"
  local future published total
  future=$(grep -c 'class="lesson future"' dist/index.html)
  published=$(grep -c 'class="lesson"' dist/index.html)
  total=$((future + published))
  [[ "$total" -eq 41 ]] || fail "expected 41 lesson cards (published + future), got $total ($published published, $future future)"
  rm -rf dist
}

test_build_index_marks_published_lessons() {
  # Scaffold a master-list lesson and confirm it lights up. Uses 40-capstone-ship
  # because it's in the build_index master list AND is the last lesson in the
  # course — least likely to collide with the lesson the author is currently
  # working on. (Earlier picks like 00-setup wiped the real lesson when the
  # harness ran in the same working tree.)
  local name="40-capstone-ship"
  # Back up any pre-existing lesson dir (e.g., once lesson 40 is authored).
  local backup=""
  if [[ -d "lessons/$name" ]]; then
    backup=$(mktemp -d)
    mv "lessons/$name" "$backup/$name"
  fi
  rm -rf dist
  tools/new-lesson "$name" >/dev/null
  if ! elixir tools/build_index/build_index.exs \
      --lessons lessons --shared shared/reveal --out dist >/tmp/build-index.out 2>&1; then
    cat /tmp/build-index.out >&2
    rm -rf "lessons/$name" dist
    [[ -n "$backup" ]] && mv "$backup/$name" "lessons/$name" && rm -rf "$backup"
    fail "build_index exited non-zero"
  fi
  assert_file "dist/lessons/$name/slides/index.html"
  assert_grep "lessons/$name/slides/" "dist/index.html"
  rm -rf "lessons/$name" dist
  # Restore the backup if there was one.
  [[ -n "$backup" ]] && mv "$backup/$name" "lessons/$name" && rm -rf "$backup"
  return 0
}

main "$@"
